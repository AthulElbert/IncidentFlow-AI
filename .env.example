# Integration modes: mock | real
JIRA_MODE=mock
JENKINS_MODE=mock

# Storage backend: json | postgres
STORAGE_BACKEND=json
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic_support

# Triage mode: heuristic | llm
TRIAGE_MODE=heuristic
TRIAGE_CONFIDENCE_FLOOR=0.60

# LLM triage settings (required when TRIAGE_MODE=llm)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=20
LLM_VERIFY_SSL=true

# APM evidence collection mode: mock | http
APM_MODE=mock
APM_BASE_URL=http://localhost:9001
APM_VERIFY_SSL=true
APM_TIMEOUT_SECONDS=10

# Dev evidence thresholds
DEV_MIN_APM_IMPROVEMENT_PCT=5.0
REQUIRE_DEV_SMOKE_TESTS=true

# Authentication / RBAC
# AUTH_MODE: api_key | jwt | hybrid
AUTH_ENABLED=true
AUTH_MODE=api_key

# API key auth (used in api_key/hybrid mode)
VIEWER_API_KEY=viewer-local-key
VIEWER_ACTOR=viewer-user
APPROVER_API_KEY=approver-local-key
APPROVER_ACTOR=approver-user
RELEASE_OPERATOR_API_KEY=release-local-key
RELEASE_OPERATOR_ACTOR=release-operator-user

# JWT auth (used in jwt/hybrid mode)
JWT_SECRET=replace-with-32-plus-char-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=agentic-support
JWT_AUDIENCE=agentic-support-api
JWT_ROLE_CLAIM=role
JWT_ACTOR_CLAIM=sub

# Logging
LOG_LEVEL=INFO

# Policy checks before final prod readiness
MIN_CONFIDENCE_FOR_PROD=0.80
REQUIRE_ZERO_WARNINGS_FOR_PROD=true
ALLOWED_JENKINS_STATES_FOR_PROD=QUEUED,SUCCESS

# Jira (required when JIRA_MODE=real)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_PROJECT_KEY=SUP
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# Jenkins (required when JENKINS_MODE=real)
JENKINS_BASE_URL=https://jenkins.company.com
JENKINS_USER=your-jenkins-user
JENKINS_API_TOKEN=your-jenkins-api-token
JENKINS_JOB_SUFFIX=-dev-validation
JENKINS_PROD_JOB_SUFFIX=-prod-deploy
JENKINS_VERIFY_SSL=true
